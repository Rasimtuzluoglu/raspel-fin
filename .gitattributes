# Auto detect text files and perform LF normalization
* text=auto

# Java / Maven / config files: LF
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.env.example text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf
Dockerfile text eol=lf
mvnw text eol=lf

# Windows batch scripts: CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
